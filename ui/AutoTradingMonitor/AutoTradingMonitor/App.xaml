<Application x:Class="AutoTradingMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AutoTradingMonitor"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Primitives/Spacing/Typography -->
                <ResourceDictionary Source="Resources/Themes/Primitives.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Spacing.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Typography.xaml"/>

                <!-- Theme Colors -->
                <ResourceDictionary Source="Resources/Themes/Base/Navi.xaml"/>

                <!-- Controls/Layout -->
                <ResourceDictionary Source="Resources/Themes/Controls/Buttons.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Layout/TopBar.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Layout/SideBar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
