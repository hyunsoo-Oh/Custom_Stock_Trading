<Window x:Class="AutoTradingMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoTradingMonitor"
        xmlns:views="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Background="{DynamicResource Brush.WindowBackground}"
        Title="Auto Trading Monitor" Height="800" Width="1280">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.TopBar}" Height="{StaticResource Layout.TopPanelHeight}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource Layout.LeftPanelWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side of Top Bar -->
                <Border Grid.Column="0" Background="{DynamicResource Brush.TopBarLeft}" Padding="12,0"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="0,0,1,1">
                    <DockPanel LastChildFill="True" VerticalAlignment="Center">
                        <!-- Logo Placeholder -->
                        <Border Width="38" Height="28" CornerRadius="6"
                                Background="{DynamicResource Brush.PanelAlt}"
                                DockPanel.Dock="Left"
                                Margin="0,0,10,0">
                            <TextBlock Text="V1.0" Foreground="{DynamicResource Brush.TextPrimary}"  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Trading Dashboard" 
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    FontSize="{StaticResource FontSize.Title}"
                                    FontWeight="{StaticResource FontWeight.SemiBold}"/>
                            <TextBlock Text="Disconnect | Server"                                       
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       FontSize="{StaticResource FontSize.Caption}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Right Side of Top Bar -->
                <Border Grid.Column="1" Background="{DynamicResource Brush.TopBarRight}" Margin="4,0,0,0"
                        BorderBrush="{StaticResource Brush.BorderStrong}"
                        BorderThickness="1,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- upper status -->
                            <RowDefinition Height="Auto"/>
                            <!-- ribbon -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Uppper Status -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource Brush.TopBarRight}"
                                BorderBrush="{DynamicResource Brush.BorderStrong}"
                                BorderThickness="0,0,0,1"
                                Padding="8,4">          
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" Fill="{Binding KRMarketBrush}"/>
                                    <TextBlock Text="KR : " Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding KRMarketText}" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>

                                    <TextBlock Text="  |  " Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>

                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" Fill="{Binding USMarketBrush}"/>
                                    <TextBlock Text="US : " Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding USMarketText}" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Right -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LocalTime}" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                    <TextBlock Text=" | " Foreground="{DynamicResource Brush.TextSecondary}"/>
                                    <TextBlock Text="{Binding Latency, StringFormat=Latency {0}ms}" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Bottom: TopBarWidget goes here -->
                        <Grid Grid.Row="1" Margin="0,4,0,0">
                            <views:TopBarWidget DataContext = "{Binding TopBar}">
                            </views:TopBarWidget>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="0,4,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <!-- Left Panel -->
                <ColumnDefinition Width="{StaticResource Layout.LeftPanelWidth}"/>
                <!-- Main Content Area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Side Navigation Panel -->
            <Border Grid.Column="0" Background="{DynamicResource Brush.SideBar}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Background="{DynamicResource Brush.NavHeaderBackground}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Navigation" 
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    FontWeight="{DynamicResource FontWeight.SemiBold}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Nav List -->
                    <ListBox Grid.Row="1"
                             Style="{StaticResource ListBox.Sidebar}"
                             ItemTemplate="{StaticResource NavItemTemplate}"
                             ItemContainerStyle="{StaticResource ListBoxItem.Sidebar}"
                             ItemsSource="{Binding NavItems}"
                             SelectedItem="{Binding SelectedNavItem}">
                    </ListBox>
                    <Border Grid.Row="2"  Margin="8,0,0,0">
                        <Button Style="{StaticResource Button.Nav}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" Margin="8,0,8,0"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Brush.Panel}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0"
                    Margin="4,0,0,0">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </Grid>
    </Grid>
</Window>
