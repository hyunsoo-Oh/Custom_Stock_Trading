<Window x:Class="AutoTradingMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoTradingMonitor"
        mc:Ignorable="d"
        Background="#FF1E1E1E"
        Title="Auto Trading Monitor" Height="800" Width="1280">
    
    <!-- (옵션) Layout 리소스를 아직 안 만들었다면 임시로라도 선언 -->
    <Window.Resources>
        <!-- MVVM 메뉴용 예시(나중에 VM에서 ItemsSource로 대체) -->
        <x:Array x:Key="NavItems" Type="{x:Type sys:String}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <sys:String>Dashboard</sys:String>
            <sys:String>Universe</sys:String>
            <sys:String>Theme Rotation</sys:String>
            <sys:String>Signals</sys:String>
            <sys:String>Orders</sys:String>
            <sys:String>Positions</sys:String>
            <sys:String>Reports</sys:String>
            <sys:String>Settings</sys:String>
        </x:Array>
        <!-- 선택 상태 표시를 위한 아주 최소 템플릿 -->
        <DataTemplate x:Key="NavItemTemplate">
            <Grid Margin="6,2" Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 아이콘(문자/이모지/Segoe MDL2 Assets 코드포인트 등) -->
                <TextBlock Grid.Column="0"
                       Text="{Binding Icon}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="16"/>

                <!-- 메뉴명 -->
                <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="White" VerticalAlignment="Center"  FontSize="13"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/> <!-- Main Content Area -->
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FF2D2D30" Height="{StaticResource Layout.TopPanelHeight}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource Layout.LeftPanelWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side of Top Bar -->
                <Border Grid.Column="0" Background="#FF252526" Padding="12,0">
                    <DockPanel LastChildFill="True" VerticalAlignment="Center">
                        <!-- Logo Placeholder -->
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="#FF3E3E42"
                                DockPanel.Dock="Left"
                                Margin="0,0,10,0"/>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Auto Trading Monitor" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="KRX + US | Weekly Rebalance" Foreground="#FFB0B0B0" FontSize="11"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                
                <!-- Right Side of Top Bar -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <!-- upper status -->
                        <RowDefinition Height="Auto"/>
                        <!-- ribbon -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Left: Ellipse + Disconnect -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,8,8,8">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" Fill="Red"/>
                        <TextBlock Text="Disconnect" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: timestamp + latency -->
                    <TextBlock Grid.Column="2" Text="yyyy-mm-dd hh:mm:ss | Latency 21ms"
                        VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                </Grid>
            </Grid>
        </Border>
        
        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Panel -->
                <ColumnDefinition Width="{StaticResource Layout.LeftPanelWidth}"/>
                <!-- Main Content Area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Side Navigation Panel -->
            <Border Grid.Column="0" Background="#FF2D2D30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FF2D2D30" BorderBrush="#FF3E3E42" BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Navigation" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <!-- Nav List -->
                    <ListBox Grid.Row="1" Margin="8" Background="Transparent" BorderThickness="0"
                        ItemTemplate="{StaticResource NavItemTemplate}" ItemsSource="{Binding NavItems}" SelectedItem="{Binding SelectedNavItem}">
                    </ListBox>
                    <Border Grid.Row="2">
                        <Button HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Margin="12,10,8,8">
                                <TextBlock Text="⚙" VerticalAlignment="Center"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Border Background="#FF252526" BorderBrush="#FF3E3E42" BorderThickness="0,0,0,0" Margin="10,10,10,10">
                    <ContentControl Content="MainHost" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
