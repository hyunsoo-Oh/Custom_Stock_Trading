<UserControl x:Class="AutoTradingMonitor.Presentation.Views.TopBar.Cards.GaugeMetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar.Cards"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10,6" CornerRadius="10"
            Background="{DynamicResource Brush.TopBarRight}"
            BorderBrush="{DynamicResource Brush.BorderSubtle}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Opacity="0.7" FontSize="11"/>
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Percent}" Height="8" Margin="0,6,0,0"
                 Foreground="{DynamicResource Brush.MetricUp}"
                 Background="{DynamicResource Brush.TopBarCardBorder}"/>
            <TextBlock Text="{Binding ValueText}" Opacity="0.7" FontSize="11"/>
        </StackPanel>
    </Border>
</UserControl>
