<UserControl x:Class="AutoTradingMonitor.Presentation.Views.TopBar.Cards.NumberMetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar.Cards"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Style="{StaticResource Style.TopBarCardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       Foreground="{DynamicResource Brush.TopBarTextSecondary}"
                       FontSize="11"/>

            <!-- Value -->
            <TextBlock Grid.Row="1" Margin="0,2,0,0"
                       Text="{Binding ValueText}"
                       Foreground="{DynamicResource Brush.TopBarTextPrimary}"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <!-- SubText (등락/부가 정보) -->
            <TextBlock Grid.Row="2" Text="{Binding SubText}" FontSize="11">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.MetricNeutral}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Trend}" Value="Up">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.MetricUp}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Trend}" Value="Down">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.MetricDown}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
