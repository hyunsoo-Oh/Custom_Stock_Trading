<UserControl x:Class="AutoTradingMonitor.Presentation.Views.TopBar.Cards.SparklineMetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar.Cards"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border Style="{StaticResource Style.TopBarCardBorder}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 상단 텍스트 영역 ===== -->
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource Style.TopBarTitleText}"/>

                <TextBlock Text="{Binding ValueText}"
                           Style="{StaticResource Style.TopBarValueText}"
                           FontSize="16"/>
            </StackPanel>

            <!-- ===== 스파크라인 영역 ===== -->
            <Grid Grid.Row="1"
                  Margin="0,6,0,0"
                  Background="{DynamicResource Brush.TopBarGraphArea}"
                  ClipToBounds="True">

                <!-- 얇은 하단 기준선 -->
                <Border VerticalAlignment="Bottom"
                        Height="1"
                        Background="{DynamicResource Brush.TopBarCardBorder}"
                        Opacity="0.6"/>

                <!-- 실제 라인 -->
                <Polyline Stroke="{DynamicResource Brush.MetricUp}"
                          StrokeThickness="1.5"
                          Points="{Binding Series, Converter={StaticResource SparklineConverter}}"
                          SnapsToDevicePixels="True"/>

            </Grid>

        </Grid>

    </Border>
</UserControl>
