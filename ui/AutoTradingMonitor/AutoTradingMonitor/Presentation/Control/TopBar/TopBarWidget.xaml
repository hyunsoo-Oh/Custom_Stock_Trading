<UserControl x:Class="AutoTradingMonitor.Presentation.Views.TopBar.TopBarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar"
             xmlns:vm="clr-namespace:AutoTradingMonitor.Presentation.ViewModels.TopBar.Metrics"
             xmlns:cards="clr-namespace:AutoTradingMonitor.Presentation.Views.TopBar.Cards"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- ✅ VM 타입별로 카드(UserControl) 자동 선택 -->
        <DataTemplate DataType="{x:Type vm:NumberMetricVm}">
            <cards:NumberMetricCard/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SparklineMetricVm}">
            <cards:SparklineMetricCard/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:GaugeMetricVm}">
            <cards:GaugeMetricCard/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ItemsControl ItemsSource="{Binding Metrics}">

            <!-- 배치: “항상 한 줄, 스크롤 없음, 줄바꿈 없음” -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- 간격/정렬 -->
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Margin" Value="6,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

        </ItemsControl>
    </Grid>
</UserControl>
