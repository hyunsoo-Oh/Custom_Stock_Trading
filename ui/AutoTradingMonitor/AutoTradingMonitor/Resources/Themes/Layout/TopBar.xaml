<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- ===== TopBar 카드 톤 ===== -->
    <!-- 카드 배경: TopBar 배경보다 아주 살짝 밝게 -->
    <SolidColorBrush x:Key="Brush.TopBarCardBg" Color="#3A4C70"/>
    <SolidColorBrush x:Key="Brush.TopBarCardBgHover" Color="#3A4C70"/>

    <!-- 테두리 -->
    <SolidColorBrush x:Key="Brush.TopBarCardBorder" Color="#2B3A55"/>
    <SolidColorBrush x:Key="Brush.TopBarCardBorderStrong" Color="#3A4C70"/>

    <!-- 텍스트 톤 -->
    <SolidColorBrush x:Key="Brush.TopBarTextPrimary" Color="#F4F7FF"/>
    <SolidColorBrush x:Key="Brush.TopBarTextSecondary" Color="#C8D2E6"/>
    <SolidColorBrush x:Key="Brush.TopBarTextTertiary" Color="#93A3C2"/>

    <!-- 상태 색 (상승/하락/중립) -->
    <SolidColorBrush x:Key="Brush.MetricUp" Color="#2BD576"/>
    <SolidColorBrush x:Key="Brush.MetricDown" Color="#FF5C5C"/>
    <SolidColorBrush x:Key="Brush.MetricNeutral" Color="#7F8AA6"/>

    <!-- 공통 수치 폰트 크기 -->
    <sys:Double x:Key="Font.TopBarTitle">11</sys:Double>
    <sys:Double x:Key="Font.TopBarValue">18</sys:Double>
    <sys:Double x:Key="Font.TopBarSub">11</sys:Double>

    <Style x:Key="Style.TopBarCardBorder" TargetType="Border">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource Brush.TopBarCardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.TopBarCardBorderStrong}"/>
        <Setter Property="BorderThickness" Value="1.25"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Style.TopBarTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TopBarTextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Style.TopBarValueText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TopBarTextPrimary}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="Style.TopBarSubText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TopBarTextTertiary}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- 스파크라인 그래프 배경 -->
    <SolidColorBrush x:Key="Brush.TopBarGraphArea" Color="#0F1624"/>

</ResourceDictionary>