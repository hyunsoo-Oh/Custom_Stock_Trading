<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 네비게이션 아이템 템플릿 (MainWindow에서 ItemsSource 바인딩을 유지) -->
    <!-- ListBox 기본 -->
    <Style x:Key="ListBox.Sidebar" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <!-- ListBoxItem: Hover/Selected 룩 -->
    <Style x:Key="ListBoxItem.Sidebar" TargetType="ListBoxItem">
        <Setter Property="Height" Value="{DynamicResource Size.NavItemHeight}"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="{DynamicResource Radius.Small}">
                        <Grid>
                            <Border x:Name="AccentBar"
                                Width="3"
                                Background="Transparent"
                                HorizontalAlignment="Left"
                                CornerRadius="2"/>
                            <ContentPresenter Margin="10,0,8,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.NavItemHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.NavItemSelected}"/>
                            <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Brush.NavItemSelectedBorder}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 네가 쓰던 NavItemTemplate -->
    <DataTemplate x:Key="NavItemTemplate">
        <!-- 지금은 String 기준 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 아이콘 -->
            <TextBlock Grid.Column="0"
                   Text="{Binding Icon}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   FontSize="14"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

            <!-- 제목 -->
            <TextBlock Grid.Column="2"
                   Text="{Binding Title}"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>
        </Grid>
    </DataTemplate>
</ResourceDictionary>