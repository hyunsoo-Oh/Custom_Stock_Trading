<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.WindowBackground">#FF0F172A</Color>
    <Color x:Key="Color.TopBar">#FF172033</Color>
    <Color x:Key="Color.TopBarLeft">#FF0F172A</Color>
    <Color x:Key="Color.TopBarRight">#FF0F172A</Color>
    <Color x:Key="Color.SideBar">#FF222B3A</Color>
    <Color x:Key="Color.Panel">#FF253247</Color>
    <Color x:Key="Color.PanelAlt">#FF25314A</Color>
    <Color x:Key="Color.Border">#FF334155</Color>
    <Color x:Key="Color.BorderStrong">#FF465A78</Color>
    <Color x:Key="Color.BorderSubtle">#FF334155</Color>

    <Color x:Key="Color.Accent">#FF2563EB</Color>
    <Color x:Key="Color.Danger">#FFF87171</Color>

    <Color x:Key="Color.TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.TextSecondary">#FFD1D5DB</Color>
    <Color x:Key="Color.TextMuted">#FF9CA3AF</Color>

    <!-- Sidebar States -->
    <!-- Navigation Header -->
    <Color x:Key="Color.NavHeaderBackground">#FF162338</Color>
    <Color x:Key="Color.NavHeaderText">#FFF2F2F2</Color>
    <Color x:Key="Color.NavHeaderDivider">#FF2B2B2F</Color>
    
    <!-- Navigation List -->
    <Color x:Key="Color.NavItemHover">#FF343437</Color>
    <Color x:Key="Color.NavItemSelected">#FF3A3A3E</Color>
    <Color x:Key="Color.NavItemSelectedBorder">#FF0078D7</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.WindowBackground" Color="{StaticResource Color.WindowBackground}" />
    <SolidColorBrush x:Key="Brush.TopBar" Color="{StaticResource Color.TopBar}" />
    <SolidColorBrush x:Key="Brush.TopBarLeft" Color="{StaticResource Color.TopBarLeft}" />
    <SolidColorBrush x:Key="Brush.TopBarRight" Color="{StaticResource Color.TopBarRight}" />
    <SolidColorBrush x:Key="Brush.SideBar" Color="{StaticResource Color.SideBar}" />
    <SolidColorBrush x:Key="Brush.Panel" Color="{StaticResource Color.Panel}" />
    <SolidColorBrush x:Key="Brush.PanelAlt" Color="{StaticResource Color.PanelAlt}" />
    
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}" />
    
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.NavHeaderBackground" Color="{StaticResource Color.NavHeaderBackground}" />
    <SolidColorBrush x:Key="Brush.NavHeaderText" Color="{StaticResource Color.NavHeaderText}" />
    <SolidColorBrush x:Key="Brush.NavHeaderDivider" Color="{StaticResource Color.NavHeaderDivider}" />
    
    <SolidColorBrush x:Key="Brush.NavItemHover" Color="{StaticResource Color.NavItemHover}" />
    <SolidColorBrush x:Key="Brush.NavItemSelected" Color="{StaticResource Color.NavItemSelected}" />
    <SolidColorBrush x:Key="Brush.NavItemSelectedBorder" Color="{StaticResource Color.NavItemSelectedBorder}" />

</ResourceDictionary>